# Hermes Control Interface — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All settings are environment variables. You can also pass them via your
# hosting platform, systemd Environment= directives, or a secret manager.
# The .env file is gitignored — it never enters version control.

# Required

# Password for the login screen. Use a long random string in production.
# Generate one with: openssl rand -hex 32
HERMES_CONTROL_PASSWORD=

# HMAC secret for signing auth tokens and internal request verification.
# Generate one with: openssl rand -hex 32
HERMES_CONTROL_SECRET=

# Optional

# HTTPS support (optional — browsers may force HTTPS on IP addresses).
# Generate self-signed certs with:
#   openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes -subj "/CN=<your-ip-or-hostname>"
# Note: SSL_CERT_FILE is a macOS/system reserved variable — use the HCI_ prefix.
# HCI_SSL_CERT_FILE=/path/to/cert.pem
# HCI_SSL_KEY_FILE=/path/to/key.pem
#
# Port to listen on. Default: 10272
# HTTPS support (optional — browsers may force HTTPS on IP addresses).
# Generate self-signed certs with:
#   openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes -subj "/CN=<your-ip-or-hostname>"
# Note: SSL_CERT_FILE is a macOS/system reserved variable — use the HCI_ prefix.
# HCI_SSL_CERT_FILE=/path/to/cert.pem
# HCI_SSL_KEY_FILE=/path/to/key.pem

# Port to listen on. Default: 10272
# PORT=10272

# Path to Hermes root directory (file explorer root).
# Default: ~/.hermes (resolved at runtime via os.homedir())
# This is the top-level .hermes directory, NOT a profile subdirectory.
# HERMES_CONTROL_HOME=~/.hermes

# Root directory for the projects explorer panel.
# Default: parent directory of the repo
# HERMES_PROJECTS_ROOT=~/projects

# Override explorer root directories (comma-separated paths, or JSON array).
# See docs/CONFIG.md for full format.
# HERMES_CONTROL_ROOTS=~/projects,~/.hermes

# ── Gateway API ──

# API key for authenticating with Hermes Gateway API (api_server).
# Default: reads from ~/.hermes/config.yaml → platforms.api_server.extra.key
# Only set this if your gateway key differs from config.yaml or you need to override.
# GATEWAY_API_KEY=your-gateway-api-key

# ── CORS ──

# Allowed origins for gateway config injection (comma-separated).
# Default: auto-detects from request Origin header, falls back to localhost dev ports.
# Set this when deploying to a custom domain (not localhost).
# HCI_CORS_ORIGINS=https://your-domain.com,https://staging.your-domain.com
